{
  "name": "translator-server",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint && tsc -b",
    "format": "prettier --check .",
    "fix": "prettier --write . && eslint --fix",
    "check": "npm run lint && npm run format",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "secrets:bulk": "wrangler secret bulk .prod.vars",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply translator-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply translator-db --remote"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "ai": "^6.0.149",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "mustache": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "workers-ai-provider": "^3.1.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
